# GTM (client-side)
# Use the numeric ID from the GTM URL — NOT "GTM-XXXXXX", numbers only
# Example: https://tagmanager.google.com/#/container/accounts/40182/containers/12345678/
#                                                             ^^^^^              ^^^^^^^^
#                                                         ACCOUNT_ID         CONTAINER_ID
GTM_ACCOUNT_ID=123456789
GTM_CLIENT_CONTAINER_ID=987654321

# GTM (server-side) — leave blank if not used
GTM_SERVER_CONTAINER_ID=

# Google Sheets — paste the full URL as-is
GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/xxxxx/edit

# Claude API key — leave blank to skip AI explanations
ANTHROPIC_API_KEY=

# Execution mode: latest (default) / all
MODE=latest

# Output language: en (default) / ja
LANGUAGE=ja
